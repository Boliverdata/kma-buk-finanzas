# Renombra este archivo a secrets.toml y completa con tus credenciales.
# NUNCA subas secrets.toml al repositorio (está en .gitignore).

# JSON completo de la service account de Google (una sola línea)
GOOGLE_CREDENTIALS = '{"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}'

# Clave de Google AI Studio para el chatbot Gemini (gratis)
# Obtener en: https://aistudio.google.com/apikey
GEMINI_API_KEY = "AIza..."
